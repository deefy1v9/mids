# ===========================================
# TenFront API
# ===========================================
TENFRONT_BASE_URL=https://api.tenfront.com.br/v1
TENFRONT_CONSUMER_KEY=seu_consumer_key
TENFRONT_CONSUMER_SECRET=seu_consumer_secret
TENFRONT_BEARER_TOKEN=seu_bearer_token

# ===========================================
# Kommo CRM
# ===========================================
KOMMO_SUBDOMAIN=seu_subdominio
KOMMO_ACCESS_TOKEN=seu_access_token

# ===========================================
# Cron Schedule
# ===========================================
CRON_SCHEDULE=0 8 * * *

# ===========================================
# Banco de dados
# ===========================================
DATABASE_URL=postgresql://postgres:senha@localhost:5432/mids

# ===========================================
# Login do painel
# ===========================================
APP_SECRET=sua_senha_de_acesso
